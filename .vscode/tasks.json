{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Typescript (oufr) watch",
      "type": "process",
      "command": "node",
      "args": ["./node_modules/typescript/bin/tsc", "-p", "packages/react/tsconfig.json", "-w", "--noEmit"],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Typescript (vr-tests) watch",
      "type": "process",
      "command": "node",
      "args": ["./node_modules/typescript/bin/tsc", "-p", "apps/vr-tests/tsconfig.json", "-w", "--noEmit"],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Typescript (experiments) watch",
      "type": "process",
      "command": "node",
      "args": ["./node_modules/typescript/bin/tsc", "-p", "packages/react-experiments/tsconfig.json", "-w", "--noEmit"],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Typescript (react-docsite-components) watch",
      "type": "process",
      "command": "node",
      "args": [
        "./node_modules/typescript/bin/tsc",
        "-p",
        "packages/react-docsite-components/tsconfig.json",
        "-w",
        "--noEmit"
      ],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Storybook v9 docsite",
      "type": "shell",
      "command": "yarn",
      "args": ["workspace", "@fluentui/public-docsite-v9", "start"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build react-file-type-icons",
      "type": "shell",
      "command": "yarn",
      "args": ["nx", "run", "react-file-type-icons:build", "--outputStyle=stream", "--skip-nx-cache"],
      "isBackground": false
    }
  ]
}
