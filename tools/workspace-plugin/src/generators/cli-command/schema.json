{
  "$schema": "http://json-schema.org/schema",
  "cli": "nx",
  "id": "cli-command",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Command name (e.g. 'migrate', 'report')",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use for the CLI command?",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "description": "Short description of the command shown in --help",
      "default": "TODO: Add description",
      "x-prompt": "Provide a short description for the command:"
    },
    "skipFormat": {
      "description": "Skip formatting files",
      "type": "boolean",
      "default": false
    }
  },
  "required": ["name"]
}
