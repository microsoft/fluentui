{
  "name": "react-storybook-addon-export-to-sandbox",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "implicitDependencies": [],
  "sourceRoot": "packages/react-components/react-storybook-addon-export-to-sandbox/src",
  "tags": ["vNext", "platform:any", "tools"],
  "targets": {
    "build": {
      "options": {
        "assets": [
          {
            "input": "{projectRoot}/src",
            "output": "dist",
            "glob": "styles.css"
          }
        ]
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "node __tests__/webpack-integration.cjs"
      }
    }
  }
}
