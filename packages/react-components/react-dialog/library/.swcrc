{
  "exclude": [
    "/testing",
    "/**/*.cy.ts",
    "/**/*.cy.tsx",
    "/**/*.spec.ts",
    "/**/*.spec.tsx",
    "/**/*.test.ts",
    "/**/*.test.tsx"
  ],
  "jsc": {
    "experimental": {
      "plugins": [["swc-plugin-de-indent-template-literal", {}]]
    },
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": false,
      "dynamicImport": false
    },
    "externalHelpers": true,
    "transform": {
      "react": {
        "runtime": "classic",
        "useSpread": true
      }
    }
  },
  "minify": false,
  "sourceMaps": true,
  "env": {
    "targets": {
      "chrome": "115",
      "edge": "115",
      "firefox": "116",
      "safari": "16"
    }
  }
}
